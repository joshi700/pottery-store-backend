# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pottery-store?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Razorpay Webhook Secret (for verifying webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Server
PORT=5000
NODE_ENV=development

# Admin Credentials (for initial admin user)
ADMIN_EMAIL=admin@pottery.com
ADMIN_PASSWORD=admin123

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
